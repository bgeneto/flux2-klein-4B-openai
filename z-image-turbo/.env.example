# API key for Bearer authentication. Set empty to disable authentication.
API_KEY=sk-local

# Docker build-time Ubuntu apt mirror.
APT_MIRROR=https://ubuntu.c3sl.ufpr.br/ubuntu/

MODEL_ID=z-image-turbo
MODEL_PATH=/models/z_image_turbo-Q4_K.gguf
VAE_PATH=/models/ae.safetensors
# Optional fallback decoder. Leave empty unless you have a compatible --taesd model.
TAESD_PATH=
LLM_PATH=/models/Qwen3-4B-Instruct-2507-Q4_K_M.gguf

OUTPUT_DIR=/data/outputs
# Optional external origin used when returning image file URLs.
# Set this when running behind a reverse proxy or if you want to serve files from a different domain.
PUBLIC_BASE_URL=
SD_SERVER_LISTEN_IP=127.0.0.1
SD_SERVER_PORT=1234
SD_SERVER_START_TIMEOUT_SECONDS=120
SD_SERVER_POLL_INTERVAL_SECONDS=1.0

MAX_CONCURRENT_JOBS=1
QUEUE_MAXSIZE=16
JOB_TIMEOUT_SECONDS=180
RETENTION_HOURS=72

DEFAULT_STEPS=8
DEFAULT_CFG_SCALE=1.0
DEFAULT_SAMPLER=euler
DEFAULT_RNG=cuda
DEFAULT_GUIDANCE=
DEFAULT_THREADS=0

ENABLE_OFFLOAD_TO_CPU=true
ENABLE_DIFFUSION_FA=true
ENABLE_VAE_CONV_DIRECT=false
ENABLE_VAE_TILING=false
ENABLE_CLIP_ON_CPU=false
ENABLE_MMAP=false
DISABLE_IMAGE_METADATA=false

LOG_LEVEL=INFO
