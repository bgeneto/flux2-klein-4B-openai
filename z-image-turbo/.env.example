# API key for Bearer authentication. Set empty to disable authentication.
API_KEY=sk-local

# SGLang backend URL (internal to Docker network).
SGLANG_URL=http://localhost:30010

# Optional external origin used when returning image file URLs.
PUBLIC_BASE_URL=

# HuggingFace token for downloading Z-Image Turbo weights (required).
HF_TOKEN=

# Z-Image Turbo mode: "fast" (lower latency) or "lowvram" (CPU offload).
ZIMAGE_MODE=fast

# Nunchaku INT4 precision and rank (r32 = fastest, r128 = better quality).
ZIMAGE_PRECISION=int4
ZIMAGE_RANK=32

# Number of inference steps (Z-Image Turbo is optimized for ~8 steps).
NUM_INFERENCE_STEPS=8

# Guidance scale (Z-Image Turbo uses 0.0 by default).
GUIDANCE_SCALE=0.0

# Default image dimensions.
DEFAULT_HEIGHT=1024
DEFAULT_WIDTH=1024

# Diffusion transformer and VAE precision.
DIT_PRECISION=bf16
VAE_PRECISION=fp16

# Logging verbosity.
LOG_LEVEL=INFO
